# This .gitignore file is intended for Unity projects.
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
UserSettings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated JetBrains Rider plugin files
.idea/
*.sln.iml

# Visual Studio temporary files, build results, and
# user-specific files
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta

# Unity generated files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity Cache Server
/Library/ScriptAssemblies/

# Builds
*.apk
*.unitypackage

# Crash reports
sysinfo.txt

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Thumbnails
._.DS_Store

# Thumbnails
Thumbs.db

# Yarn spinner generated
*.yarn

# Uncomment if you have the Visual Studio Code extension settings for Unity:
# .vscode/
